# Reachy Claw — Environment Configuration
# Copy to .env and customize as needed:  cp .env.example .env

# Data directory — all persistent data (captures, face DB, etc.)
# Default: ~/reachy-data
# DATA_DIR=/home/recomputer/reachy-data

# Serial port for Reachy Mini (auto-detect by default)
# SERIAL_PORT=auto

# Camera device
# CAMERA_DEVICE=/dev/video1

# Source code mount (dev only — remove for production)
# REACHY_CLAW_SRC=/home/recomputer/reachy-claw-src/src/reachy_claw
