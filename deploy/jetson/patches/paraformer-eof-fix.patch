--- a/sherpa-onnx/csrc/online-recognizer-paraformer-impl.h
+++ b/sherpa-onnx/csrc/online-recognizer-paraformer-impl.h
@@ -141,7 +141,14 @@ class OnlineRecognizerParaformerImpl : public OnlineRecognizerImpl {
   }

   bool IsReady(OnlineStream *s) const override {
-    return s->GetNumProcessedFrames() + chunk_size_ < s->NumFramesReady();
+    int32_t num_unprocessed =
+        s->NumFramesReady() - s->GetNumProcessedFrames();
+    if (num_unprocessed >= chunk_size_) return true;
+    // After InputFinished(), force-decode the remaining partial chunk
+    if (num_unprocessed > 0 &&
+        s->IsLastFrame(s->NumFramesReady() - 1)) {
+      return true;
+    }
+    return false;
   }

   void DecodeStreams(OnlineStream **ss, int32_t n) const override {
@@ -195,8 +202,27 @@ class OnlineRecognizerParaformerImpl : public OnlineRecognizerImpl {

  private:
   void DecodeStream(OnlineStream *s) const {
+    int32_t num_frames_ready = s->NumFramesReady();
     const auto num_processed_frames = s->GetNumProcessedFrames();
-    std::vector<float> frames = s->GetFrames(num_processed_frames, chunk_size_);
-    s->GetNumProcessedFrames() += chunk_size_ - 1;
+    int32_t num_unprocessed = num_frames_ready - num_processed_frames;
+    bool is_last_chunk =
+        s->IsLastFrame(num_frames_ready - 1) &&
+        num_unprocessed < chunk_size_;
+
+    int32_t actual_chunk =
+        is_last_chunk ? num_unprocessed : chunk_size_;
+
+    std::vector<float> frames =
+        s->GetFrames(num_processed_frames, actual_chunk);
+
+    // Zero-pad partial final chunk to chunk_size_ so LFR/encoder
+    // receive the expected number of frames
+    if (is_last_chunk && actual_chunk < chunk_size_) {
+      int32_t feat_dim = config_.feat_config.feature_dim;
+      frames.resize(chunk_size_ * feat_dim, 0.0f);
+    }
+
+    // Advance by actual_chunk - 1 (or chunk_size_ - 1 for normal chunks)
+    s->GetNumProcessedFrames() +=
+        is_last_chunk ? actual_chunk : (chunk_size_ - 1);

     frames = ApplyLFR(frames);
     ApplyCMVN(&frames);
@@ -257,6 +283,17 @@ class OnlineRecognizerParaformerImpl : public OnlineRecognizerImpl {

     alpha_cache[0] = integrate;

+    // CIF force-fire: if input is finished and there is accumulated
+    // energy, emit the final token
+    if (is_last_chunk && integrate > 0.5f &&
+        !initial_hidden.empty()) {
+      // Normalize the residual hidden state
