FROM python:3.12-slim

RUN apt-get update && apt-get install -y --no-install-recommends \
    build-essential meson pkg-config \
    libcairo2-dev libgirepository1.0-dev gobject-introspection \
    libgl1 libglib2.0-0 \
    alsa-utils libpulse0 \
    && rm -rf /var/lib/apt/lists/*

RUN pip install --no-cache-dir reachy-mini

CMD ["reachy-mini-daemon", "--localhost-only", "--deactivate-audio"]
